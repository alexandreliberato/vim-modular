{
  "_c": "-------------------------------------",
  "_c": "LANGUAGE SERVERS",
  "_c": "-------------------------------------",

  "languageserver": {
    "elixir": {
      "command": "expert",
      "args": ["--stdio"],
      "filetypes": ["ex", "elixir", "eelixir", "heex"],
      "rootPatterns": ["mix.exs", ".git"]
    },
    "golang": {
      "command": "gopls",
      "rootPatterns": [".git/"],
      "filetypes": ["go"],
      "initializationOptions": {
        "workspace.workspaceFolderCheckCwd": true,
        "usePlaceholders": true,
        "hints": {
          "parameterNames": true,
          "assignVariableTypes": true,
          "constantValues": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "functionTypeParameters": true,
          "rangeVariableTypes": true
        }      
      }
    },
    "lua": {
        "command": "/home/alexandre.macedo/.local/lls/bin/lua-language-server",
        "cwd": "/home/alexandre.macedo/.local/lls",
        "filetypes": ["lua"],
        "rootPatterns": [".git/"]
    },
    "python": {
      "command": "bin/pyright-langserver",
      "args": ["--stdio"],
      "filetypes": ["python"],
      "settings": {
        "python": {
          "analysis": {
            "autoSearchPaths": true,
            "useLibraryCodeForTypes": true,
            "typeCheckingMode": "basic"
          }
        }
      }
    }
  },

"_": "-------------------------------------",
  "_": "DIAGNOSTICS",
  "_": "-------------------------------------",
"diagnostic-languageserver.linters": {
  "hadolint": {
    "command": "hadolint",
    "debounce": 100,
    "args": ["-"],
    "offsetLine": 0,
    "offsetColumn": 0,
    "sourceName": "hadolint",
    "formatLines": 1,
    "formatPattern": [
      "^.*:(\\d+):(\\d+)\\s+([^\\s]+)\\s+(.*)$",
      {
        "line": 1,
        "column": 2,
        "message": 4,
        "security": 3
      }
    ],
    "securities": {
      "error": "error",
      "warning": "warning"
    }
  }
},

  "diagnostic-languageserver.filetypes": {
    "vim": "vint",
    "email": "languagetool",
    "markdown": [ "write-good", "markdownlint" ],
    "sh": "shellcheck",
    "elixir": ["mix_credo", "mix_credo_compile"],
    "eelixir": ["mix_credo", "mix_credo_compile"],
    "php": ["phpstan", "psalm"],
    "yaml": [ "yamllint" ],
    "cmake": [ "cmake-lint", "cmakelint" ],
    "systemd": "systemd-analyze",
    "dockerfile": "hadolint"
  },

  "_": "-------------------------------------",
  "_": "GENERAL",
  "_": "-------------------------------------",

  "inlayHint.enable": true,
  "inlayHint.display": false,

  "signature.enable": true,
  "signature.floatConfig": { "border": true },

  "suggest.noselect": true,

  "_comment": "Package Manager Settings",
  "npm.binPath": "pnpm",

  "_comment": "Extension Management",
  "coc.preferences.packageManager": "pnpm",
  "coc.preferences.extensionUpdateCheck": "daily",
  "coc.preferences.useQuickfixForLocations": true,

  "_comment": "-------------------------------------",
  "_comment": "GOLANG",

  "go.goplsOptions": {
    "gofumpt": true,
    "completeUnimported": true
  },

  "_comment": "-------------------------------------",
  "_comment": "LUA",

  "Lua.runtime.version": "LuaJIT", 
  "Lua.diagnostics.globals": ["hs", "vim", "it", "describe", "before_each", "after_each"],
  "Lua.format.enable": true,
  
  "_comment": "-------------------------------------",
  "_comment": "TYPESCRIPT",

  "_comment": "TypeScript Settings",
  "tsserver.npm": "pnpm",
  "tsserver.enable": true,
  "tsserver.useLocalTsdk": true,
  
  "_comment": "Linter settings",
  "eslint.packageManager": "pnpm",
  "eslint.workingDirectories": [{ "mode": "auto" }],
  
  "_comment": "Formatter settings",
  "prettier.packageManager": "pnpm",
  
  "_comment": "Language server settings",
  "workspace.workspaceFolderCheckCwd": true,
  

  "_comment": "-------------------------------------",
  "_comment": "PYTHON",

  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.pythonPath": ".venv/bin/python",
  "_comment":
  "// adds the folder that contains this file to sys.path",
  "python.analysis.extraPaths": ["./"],                       

  "list.source.references.defaultArgs": ["--normal"],

  "_comment": "-------------------------------------",
  "_comment": "SQL",
  "sql.database": "postgresql"
}
